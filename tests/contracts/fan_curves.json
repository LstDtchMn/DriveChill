        "properties": {
          "id":      { "type": "string" },
          "fan_id":  { "type": "string" },
          "enabled": { "type": "boolean" },
          "points":  { "type": "array" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
