{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GET /api/scheduler/status",
  "type": "object",
  "required": ["profile_scheduler", "report_scheduler"],
  "properties": {
    "profile_scheduler": {
      "type": "object",
      "required": ["running"],
      "properties": {
        "running":            { "type": "boolean" },
        "active_schedule_id": { "type": ["string", "null"] },
        "last_check_at":      { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "report_scheduler": {
      "type": "object",
      "required": ["running"],
      "properties": {
        "running":       { "type": "boolean" },
        "last_check_at": { "type": ["string", "null"] },
        "schedules":     { "type": "array" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
