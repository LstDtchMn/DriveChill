{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GET /api/auth/users",
  "type": "object",
  "required": ["users"],
  "properties": {
    "users": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "username", "role"],
        "properties": {
          "id":         { "type": "integer" },
          "username":   { "type": "string" },
          "role":       { "type": "string", "enum": ["admin", "viewer"] },
          "created_at": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
