{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GET /api/drives",
  "type": "object",
  "required": ["drives", "total"],
  "properties": {
    "drives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "model"],
        "properties": {
          "id":          { "type": "string" },
          "name":        { "type": "string" },
          "model":       { "type": "string" },
          "bus_type":    { "type": "string" },
          "media_type":  { "type": "string" },
          "health_status": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "total": { "type": "integer" },
    "smartctl_available": { "type": "boolean" }
  },
  "additionalProperties": true
}
