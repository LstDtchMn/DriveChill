{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GET /api/analytics/report",
  "type": "object",
  "required": ["generated_at", "stats", "anomalies"],
  "properties": {
    "generated_at":  { "type": "string" },
    "window_hours":  { "type": "number" },
    "requested_range": {
      "type": "object",
      "properties": {
        "start": { "type": "string" },
        "end":   { "type": "string" }
      }
    },
    "returned_range": {
      "type": "object",
      "properties": {
        "start": { "type": "string" },
        "end":   { "type": "string" }
      }
    },
    "stats":     { "type": "array" },
    "anomalies": { "type": "array" },
    "top_anomalous_sensors": { "type": "array" },
    "regressions":           { "type": "array" }
  },
  "additionalProperties": true
}
