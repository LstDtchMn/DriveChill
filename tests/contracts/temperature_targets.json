{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GET /api/temperature-targets",
  "type": "object",
  "required": ["targets"],
  "properties": {
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "sensor_id", "target_temp_c", "enabled"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "drive_id": { "type": ["string", "null"] },
          "sensor_id": { "type": "string" },
          "fan_ids": { "type": "array", "items": { "type": "string" } },
          "target_temp_c": { "type": "number" },
          "tolerance_c": { "type": "number" },
          "min_fan_speed": { "type": "number" },
          "enabled": { "type": "boolean" },
          "pid_mode": { "type": "boolean" },
          "pid_kp": { "type": "number" },
          "pid_ki": { "type": "number" },
          "pid_kd": { "type": "number" }
        }
      }
    }
  },
  "additionalProperties": true
}
