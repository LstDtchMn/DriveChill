{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GET /api/settings",
  "type": "object",
  "required": ["sensor_poll_interval", "history_retention_hours", "temp_unit"],
  "properties": {
    "sensor_poll_interval":     { "type": "number" },
    "history_retention_hours":  { "type": "integer" },
    "temp_unit":                { "type": "string", "enum": ["C", "F"] },
    "hardware_backend":         { "type": "string" },
    "backend_name":             { "type": "string" },
    "fan_ramp_rate_pct_per_sec": { "type": "number" }
  },
  "additionalProperties": true
}
