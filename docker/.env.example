# DriveChill Docker environment variables
# Copy this file to .env and fill in the values you want to override.
# All variables are optional unless marked REQUIRED.

# ---------------------------------------------------------------------------
# Server binding
# ---------------------------------------------------------------------------

# IP address to listen on. 0.0.0.0 = all interfaces (default for Docker).
# Use 127.0.0.1 to restrict to localhost only (no auth required).
DRIVECHILL_HOST=0.0.0.0

# TCP port to listen on.
DRIVECHILL_PORT=8085

# ---------------------------------------------------------------------------
# Data persistence
# ---------------------------------------------------------------------------

# Directory for the SQLite database and TLS certs.
# Must match the volume mount path in docker-compose.yml.
DRIVECHILL_DATA_DIR=/app/data

# ---------------------------------------------------------------------------
# Authentication
# REQUIRED on first start when HOST is not 127.0.0.1.
# Creates the initial admin user. Remove after first start — the account
# persists in the volume and the password is stored as a bcrypt hash.
# ---------------------------------------------------------------------------
#DRIVECHILL_PASSWORD=changeme

# Force authentication even on localhost binding.
#DRIVECHILL_FORCE_AUTH=false

# Session lifetime. Accepts: Ns (seconds), Nm (minutes), Nh (hours), Nd (days).
#DRIVECHILL_SESSION_TTL=8h

# ---------------------------------------------------------------------------
# Hardware sensors
# ---------------------------------------------------------------------------

# Backend to use for hardware monitoring.
#   auto        — detect automatically (lm-sensors on Linux, LHM Direct on Windows)
#   lm_sensors  — Linux lm-sensors + psutil
#   lhm_direct  — Windows LibreHardwareMonitor DLL (requires admin + pythonnet)
#   mock        — fake data for development/testing
DRIVECHILL_HARDWARE_BACKEND=auto

# How often to poll hardware sensors (seconds).
#DRIVECHILL_SENSOR_POLL_INTERVAL=1.0

# How long to keep sensor history (hours). 168 = 1 week.
#DRIVECHILL_HISTORY_RETENTION_HOURS=168

# ---------------------------------------------------------------------------
# TLS / HTTPS
# ---------------------------------------------------------------------------

# Generate a self-signed certificate on first start (stored in DATA_DIR/tls/).
# The cert persists across restarts — it won't be regenerated if it already exists.
#DRIVECHILL_SSL_GENERATE_SELF_SIGNED=false

# Provide your own certificate and private key (PEM format).
# If set, SSL_GENERATE_SELF_SIGNED is ignored.
#DRIVECHILL_SSL_CERTFILE=/app/data/tls/drivechill.crt
#DRIVECHILL_SSL_KEYFILE=/app/data/tls/drivechill.key

# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------

# Temperature display unit: C or F.
#DRIVECHILL_TEMP_UNIT=C

# Allow webhooks and machine targets on private/RFC-1918 addresses.
# Disabled by default (SSRF protection). Enable only on isolated networks.
#DRIVECHILL_ALLOW_PRIVATE_OUTBOUND_TARGETS=false
